# .env.example

# OpenAI API Key
OPENAI_API_KEY=your_openai_api_key_here  # Replace 'your_openai_api_key_here' with your actual OpenAI API key.

# Supabase API URL
SUPABASE_URL=your_supabase_url_here  # Replace 'your_supabase_url_here' with your Supabase project URL.

# Supabase API Key
SUPABASE_API_KEY=your_supabase_api_key_here  # Replace 'your_supabase_api_key_here' with your Supabase API key.

# Fish Audio API Key
FISH_AUDIO_API_KEY=your_fish_audio_api_key_here  # Replace 'your_fish_audio_api_key_here' with your actual Fish Audio API key.

# AI Video Tool API Key
AI_VIDEO_TOOL_API_KEY=your_ai_video_tool_api_key_here  # Replace 'your_ai_video_tool_api_key_here' with your actual AI video tool API key.

# Server Configuration
SERVER_PORT=3000  # The port your server will run on.
SERVER_HOST=localhost  # The host your server will run on.
